// Prisma Schema — Cogna Platform
// Database: PostgreSQL | ORM: Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  DEVELOPER
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  SUPPORT
  FINANCE
}

enum AdjustmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentGateway {
  PAYSTACK
  MONNIFY
}
enum WalletTransactionType {
  FUNDING
  PURCHASE
  REFUND
  ADJUSTMENT
  REVERSAL
}

enum WalletTransactionDirection {
  CREDIT
  DEBIT
}

enum RefundStatus {
  REQUESTED
  COMPLETED
  FAILED
}

enum WalletFundingStatus {
  INITIALIZED
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum ApiKeyEnvironment {
  TEST
  LIVE
}

enum UserCapabilityType {
  DEVELOPER
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
}

// ─────────────────────────────────────────────
// AUTHENTICATION
// ─────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  fullName       String     @map("full_name")
  email          String     @unique
  passwordHash   String     @map("password_hash")
  role           UserRole   @default(CUSTOMER)
  adminRole      AdminRole? @map("admin_role")
  emailVerified  Boolean    @default(false) @map("email_verified")
  status         UserStatus @default(PENDING)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  refreshTokens  RefreshToken[]
  apiKeys        ApiKey[]
  orders         Order[]
  payments       Payment[]
  auditLogs      AuditLog[]
  capabilities   UserCapability[]
  wallet         Wallet?
  walletFundings WalletFunding[]
  refunds        Refund[]
  apiRequestLogs ApiRequestLog[]
  webhookEndpoints DeveloperWebhookEndpoint[]
  makerAdjustments  WalletAdjustmentRequest[] @relation("MakerRelation")
  checkerAdjustments WalletAdjustmentRequest[] @relation("CheckerRelation")
  verificationTokens VerificationToken[]
  supportTickets     SupportTicket[]
  supportMessages    SupportMessage[]
  notifications      Notification[]
  notificationPreference NotificationPreference?
  receipts           Receipt[]

  @@map("users")
}

model UserCapability {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  type      UserCapabilityType
  enabledAt DateTime           @default(now()) @map("enabled_at")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("user_capabilities")
}
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiKey {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  name       String
  apiKey     String       @unique @map("api_key")
  environment ApiKeyEnvironment @default(TEST)
  scopes     String[]     @default([])
  expiresAt  DateTime?    @map("expires_at")
  status     ApiKeyStatus @default(ACTIVE)
  lastUsedAt DateTime?    @map("last_used_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs ApiRequestLog[]

  @@map("api_keys")
}

// ─────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Provider {
  id        String         @id @default(uuid())
  name      String
  baseUrl   String         @map("base_url")
  apiKey    String         @map("api_key")       // encrypted
  apiSecret String?        @map("api_secret")    // optional
  apiConfig Json?          @map("api_config")    // provider-specific config JSON
  status    ProviderStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  products Product[]
  webhookEvents ProviderWebhookEvent[]

  @@map("providers")
}

model Product {
  id                  String         @id @default(uuid())
  providerId          String         @map("provider_id")
  providerProductId   String         @map("provider_product_id")
  categoryId          String         @map("category_id")
  name                String
  slug                String         @unique
  description         String?
  price               Decimal        @db.Decimal(10, 2)
  currency            String         @default("NGN")
  deliveryTime        String?        @map("delivery_time")
  image               String?
  active              Boolean        @default(true)
  paymentGateway      PaymentGateway @default(PAYSTACK) @map("payment_gateway")
  providerApiOverride Json?          @map("provider_api_override") // per-product overrides
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  provider Provider  @relation(fields: [providerId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  orders   Order[]

  @@index([slug])
  @@index([categoryId])
  @@map("products")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  productId         String      @map("product_id")
  providerId        String      @map("provider_id")
  providerOrderId   String?     @map("provider_order_id")
  status            OrderStatus @default(PENDING)
  amount            Decimal     @db.Decimal(10, 2)
  currency          String      @default("NGN")
  customerEmail     String      @map("customer_email")
  providerResponse  Json?       @map("provider_response")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  product Product  @relation(fields: [productId], references: [id])
  payment Payment?
  walletTransactions WalletTransaction[]
  refunds Refund[]
  supportTickets SupportTicket[]
  statusEvents   OrderStatusEvent[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id               String         @id @default(uuid())
  orderId          String         @unique @map("order_id")
  userId           String         @map("user_id")
  gateway          PaymentGateway
  gatewayReference String?        @map("gateway_reference") // ref from the gateway
  reference        String         @unique                   // internal ref
  amount           Decimal        @db.Decimal(10, 2)
  currency         String         @default("NGN")
  status           PaymentStatus  @default(PENDING)
  metadata         Json?          // gateway-specific response data
  paidAt           DateTime?      @map("paid_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([reference])
  @@map("payments")
}

// ─────────────────────────────────────────────

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  currency         String   @default("NGN")
  availableBalance Decimal  @default(0) @db.Decimal(14, 2) @map("available_balance")
  pendingBalance   Decimal  @default(0) @db.Decimal(14, 2) @map("pending_balance")
  lifetimeFunded   Decimal  @default(0) @db.Decimal(14, 2) @map("lifetime_funded")
  lifetimeSpent    Decimal  @default(0) @db.Decimal(14, 2) @map("lifetime_spent")
  version          Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  fundings     WalletFunding[]
  refunds      Refund[]
  adjustments  WalletAdjustmentRequest[]

  @@map("wallets")
}

model WalletTransaction {
  id                String                     @id @default(uuid())
  walletId          String                     @map("wallet_id")
  orderId           String?                    @map("order_id")
  type              WalletTransactionType
  direction         WalletTransactionDirection
  amount            Decimal                    @db.Decimal(14, 2)
  currency          String                     @default("NGN")
  balanceBefore     Decimal                    @db.Decimal(14, 2) @map("balance_before")
  balanceAfter      Decimal                    @db.Decimal(14, 2) @map("balance_after")
  reference         String                     @unique
  idempotencyKey    String                     @unique @map("idempotency_key")
  externalReference String?                    @unique @map("external_reference")
  source            String
  metadata          Json?
  createdAt         DateTime                   @default(now()) @map("created_at")

  wallet  Wallet         @relation(fields: [walletId], references: [id], onDelete: Restrict)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  funding WalletFunding?
  refunds Refund[]
  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model WalletFunding {
  id                  String              @id @default(uuid())
  walletId            String              @map("wallet_id")
  userId              String              @map("user_id")
  walletTransactionId String?             @unique @map("wallet_transaction_id")
  gateway             PaymentGateway
  reference           String              @unique
  gatewayReference    String?             @unique @map("gateway_reference")
  authorizationUrl    String?             @map("authorization_url")
  idempotencyKey      String              @unique @map("idempotency_key")
  amount              Decimal             @db.Decimal(14, 2)
  currency            String              @default("NGN")
  status              WalletFundingStatus @default(INITIALIZED)
  metadata            Json?
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  wallet            Wallet             @relation(fields: [walletId], references: [id], onDelete: Restrict)
  user              User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@map("wallet_fundings")
}


model Refund {
  id                  String       @id @default(uuid())
  userId              String       @map("user_id")
  orderId             String       @map("order_id")
  walletId            String       @map("wallet_id")
  walletTransactionId String?      @unique @map("wallet_transaction_id")
  amount              Decimal      @db.Decimal(14, 2)
  currency            String       @default("NGN")
  reason              String
  status              RefundStatus @default(REQUESTED)
  reference           String       @unique
  idempotencyKey      String       @unique @map("idempotency_key")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)
  @@map("refunds")
}
model PaymentEvent {
  id          String         @id @default(uuid())
  gateway     PaymentGateway
  eventId     String         @map("event_id")
  reference   String?
  payloadHash String         @map("payload_hash")
  eventType   String         @map("event_type")
  status      String         @default("RECEIVED")
  payload     Json?
  receivedAt  DateTime       @default(now()) @map("received_at")
  processedAt DateTime?      @map("processed_at")

  @@unique([gateway, eventId])
  @@unique([gateway, payloadHash])
  @@index([reference])
  @@map("payment_events")
}
// ADMIN / SYSTEM
// ─────────────────────────────────────────────

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String?  // what was affected
  entityId  String?  @map("entity_id")
  ipAddress String?  @map("ip_address")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// DEVELOPER WORKSPACE & WEBHOOKS
// ─────────────────────────────────────────────

model ApiRequestLog {
  id           String    @id @default(uuid())
  apiKeyId     String?   @map("api_key_id")
  userId       String    @map("user_id")
  method       String
  path         String
  statusCode   Int       @map("status_code")
  latencyMs    Int       @map("latency_ms")
  ipAddress    String?   @map("ip_address")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("api_request_logs")
}

model DeveloperWebhookEndpoint {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  url         String
  secret      String            // used to sign webhooks
  environment ApiKeyEnvironment @default(TEST)
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries DeveloperWebhookDelivery[]

  @@map("developer_webhook_endpoints")
}

model DeveloperWebhookDelivery {
  id          String   @id @default(uuid())
  endpointId  String   @map("endpoint_id")
  eventId     String   @map("event_id")
  eventType   String   @map("event_type")
  payload     Json
  statusCode  Int?     @map("status_code")
  response    String?  // response body from destination
  success     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  endpoint DeveloperWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@map("developer_webhook_deliveries")
}

model ProviderWebhookEvent {
  id          String    @id @default(uuid())
  providerId  String    @map("provider_id")
  eventId     String    @map("event_id")
  payloadHash String    @map("payload_hash")
  eventType   String    @map("event_type")
  status      String    @default("RECEIVED")
  payload     Json?
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, eventId])
  @@unique([providerId, payloadHash])
  @@map("provider_webhook_events")
}

model WalletAdjustmentRequest {
  id        String                  @id @default(uuid())
  walletId  String                  @map("wallet_id")
  makerId   String                  @map("maker_id")
  checkerId String?                 @map("checker_id")
  amount    Decimal                 @db.Decimal(14, 2)
  direction WalletTransactionDirection
  reason    String
  status    AdjustmentRequestStatus @default(PENDING)
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")

  wallet  Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  maker   User    @relation("MakerRelation", fields: [makerId], references: [id])
  checker User?   @relation("CheckerRelation", fields: [checkerId], references: [id])

  @@map("wallet_adjustment_requests")
}

model VerificationToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  type       TokenType
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("verification_tokens")
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

model OrderStatusEvent {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_events")
}

model SupportTicket {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  orderId   String?        @map("order_id")
  subject   String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(LOW)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order    Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages SupportMessage[]

  @@map("support_tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model SupportMessage {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  senderId  String   @map("sender_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  FUNDING
  PURCHASE
  FULFILLMENT
  REFUND
  SECURITY
}

model NotificationPreference {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  emailFunding     Boolean  @default(true) @map("email_funding")
  emailPurchase    Boolean  @default(true) @map("email_purchase")
  emailFulfillment Boolean  @default(true) @map("email_fulfillment")
  emailRefund      Boolean  @default(true) @map("email_refund")
  emailSecurity    Boolean  @default(true) @map("email_security")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Receipt {
  id        String      @id @default(uuid())
  reference String      @unique
  userId    String      @map("user_id")
  type      ReceiptType
  amount    Decimal     @db.Decimal(14, 2)
  currency  String      @default("NGN")
  entityId  String      @map("entity_id")
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

enum ReceiptType {
  FUNDING
  PURCHASE
  REFUND
  PAYMENT
}
