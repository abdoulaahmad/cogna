{
  "name": "cogna-backend",
  "version": "1.0.0",
  "description": "Cogna API — API-first AI Subscription Marketplace",
  "main": "dist/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "worker:dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "keywords": [
    "fastify",
    "typescript",
    "prisma",
    "ai",
    "marketplace"
  ],
  "author": "Abdullahi A. Ahmad",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.8",
    "vitest": "^4.1.10"
  }
}
