# Environment — Cogna Backend
# Copy this to .env and fill in values

# App
APP_NAME=Cogna
APP_ENV=development
APP_URL=http://localhost:3000
PORT=4000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cogna
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/cogna_test

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Payment Gateways
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxxxx
MONNIFY_SECRET_KEY=your-monnify-secret
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_CONTRACT_CODE=your-contract-code

# Provider fallback (actual keys stored in DB providers table)
AKUNDING_API_KEY=
AKUNDING_BASE_URL=https://akunding.com/api

# Queue
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cogna.store
